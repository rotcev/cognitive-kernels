{
  "name": "cognitive-kernels",
  "version": "0.1.0",
  "description": "Standalone cognitive kernel runtime for reusable AI process substrates",
  "type": "module",
  "bin": {
    "cognitive-kernels": "dist/cli.js",
    "cognitive-kernels-mcp": "dist/mcp-cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.50",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@openai/codex-sdk": "0.104.0",
    "smol-toml": "1.3.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "typescript": "5.8.2",
    "vitest": "3.0.8"
  }
}
